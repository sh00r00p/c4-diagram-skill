        <mxCell id="conn_10" value="Sends emails [REST/JSON]" style="endArrow=blockThin;endFill=1;fontSize=11;fontColor=#404040;strokeColor=#404040;dashed=1;dashPattern=5 5;elbow=vertical;" edge="1" source="container_order" target="ext_email" parent="1">
